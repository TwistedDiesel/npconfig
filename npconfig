#!/usr/bin/env bash
set -euo pipefail

# npconfig: ifconfig-style CLI that persists interface settings through netplan.
# Includes Wi-Fi provisioning and an interactive curses menu for headless setup.

if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
  echo "npconfig must run as root (or via sudo)." >&2
  exit 1
fi

NETPLAN_DIR=/etc/netplan
FILE_PREFIX=99-npconfig
UI_BIN=""
NETPLAN_RENDERER=""
NETPLAN_LAST_LOG=""
NP_LOG_DIR=/var/log/npconfig

has_unit_file() {
  systemctl list-unit-files "$1" 2>/dev/null | grep -q "^$1"
}

detect_netplan_renderer() {
  if [[ -n "$NETPLAN_RENDERER" ]]; then
    printf '%s' "$NETPLAN_RENDERER"
    return 0
  fi

  # Prefer the backend that is actually running (server = networkd, desktop = NM).
  if systemctl is-active --quiet NetworkManager 2>/dev/null; then
    NETPLAN_RENDERER="NetworkManager"
    printf '%s' "$NETPLAN_RENDERER"
    return 0
  fi
  if systemctl is-active --quiet systemd-networkd 2>/dev/null; then
    NETPLAN_RENDERER="networkd"
    printf '%s' "$NETPLAN_RENDERER"
    return 0
  fi

  local hinted=""
  hinted=$(grep -rh '^[[:space:]]*renderer:' "${NETPLAN_DIR}/"*.yaml 2>/dev/null | head -1 | awk '{print $2}' || true)
  if [[ "$hinted" == "NetworkManager" || "$hinted" == "networkd" ]]; then
    NETPLAN_RENDERER="$hinted"
    printf '%s' "$NETPLAN_RENDERER"
    return 0
  fi

  if has_unit_file NetworkManager.service; then
    NETPLAN_RENDERER="NetworkManager"
  else
    NETPLAN_RENDERER="networkd"
  fi
  printf '%s' "$NETPLAN_RENDERER"
}

uses_network_manager() {
  [[ "$(detect_netplan_renderer)" == "NetworkManager" ]] \
    && systemctl is-active --quiet NetworkManager 2>/dev/null
}

networkd_wifi_extra_yaml() {
  if [[ "$(detect_netplan_renderer)" == "networkd" ]]; then
    printf '      optional: true\n      dhcp6: false\n'
  fi
}

static_defaults_for_iface() {
  local iface="$1" gw dns1 dns2
  gw=$(ip -4 route show dev "$iface" default 2>/dev/null | awk '{print $3}' | head -1)
  [[ -z "$gw" ]] && gw=$(ip -4 route show default 2>/dev/null | awk '{print $3}' | head -1)
  [[ -z "$gw" ]] && gw="192.168.1.1"
  dns1=$(awk '/^nameserver / {print $2; exit}' /etc/resolv.conf 2>/dev/null || true)
  dns2=$(awk 'NR==2 && /^nameserver / {print $2; exit}' /etc/resolv.conf 2>/dev/null || true)
  [[ -z "$dns1" ]] && dns1="1.1.1.1"
  [[ -z "$dns2" ]] && dns2="8.8.8.8"
  printf '%s %s %s\n' "$gw" "$dns1" "$dns2"
}

write_netplan_dhcp() {
  local iface="$1" renderer ytype file
  renderer=$(detect_netplan_renderer)
  ytype=$(yaml_type "$iface")
  file=$(netplan_file_for "$iface")

  cat >"$file" <<YAML
network:
  version: 2
  renderer: ${renderer}
  ${ytype}:
    ${iface}:
      dhcp4: true
YAML
  secure_netplan_file "$file"
}

write_netplan_static() {
  local iface="$1" addr="$2" prefix="$3" gateway="${4:-}" dns1="${5:-}" dns2="${6:-}"
  local renderer ytype file
  if [[ -z "$gateway" || -z "$dns1" ]]; then
    read -r gateway dns1 dns2 < <(static_defaults_for_iface "$iface")
  fi
  [[ -z "$dns2" ]] && dns2="8.8.8.8"
  renderer=$(detect_netplan_renderer)
  ytype=$(yaml_type "$iface")
  file=$(netplan_file_for "$iface")

  cat >"$file" <<YAML
network:
  version: 2
  renderer: ${renderer}
  ${ytype}:
    ${iface}:
      dhcp4: false
      addresses:
        - ${addr}/${prefix}
      routes:
        - to: default
          via: ${gateway}
      nameservers:
        addresses:
          - ${dns1}
          - ${dns2}
YAML
  secure_netplan_file "$file"
}

write_netplan_wifi() {
  local iface="$1" ssid="$2" password="${3:-}" addr="${4:-}" prefix="${5:-}" hidden="${6:-0}"
  local gateway="${7:-}" dns1="${8:-}" dns2="${9:-}"
  local file renderer quoted_ssid ap_block
  renderer=$(detect_netplan_renderer)
  file=$(netplan_file_for "$iface")
  quoted_ssid=$(yaml_quote "$ssid")

  if [[ -n "$password" ]]; then
    ap_block=$(cat <<YAML
      access-points:
        ${quoted_ssid}:
          password: $(yaml_quote "$password")
YAML
)
  else
    ap_block=$(cat <<YAML
      access-points:
        ${quoted_ssid}: {}
YAML
)
  fi

  if [[ "$hidden" == "1" ]]; then
    ap_block="${ap_block}
          hidden: true"
  fi

  if [[ -n "$addr" && -n "$prefix" ]]; then
    if [[ -z "$gateway" || -z "$dns1" ]]; then
      read -r gateway dns1 dns2 < <(static_defaults_for_iface "$iface")
    fi
    [[ -z "$dns2" ]] && dns2="8.8.8.8"
    cat >"$file" <<YAML
network:
  version: 2
  renderer: ${renderer}
  wifis:
    ${iface}:
      dhcp4: false
$(networkd_wifi_extra_yaml)${ap_block}
      addresses:
        - ${addr}/${prefix}
      routes:
        - to: default
          via: ${gateway}
      nameservers:
        addresses:
          - ${dns1}
          - ${dns2}
YAML
    secure_netplan_file "$file"
  else
    cat >"$file" <<YAML
network:
  version: 2
  renderer: ${renderer}
  wifis:
    ${iface}:
      dhcp4: true
$(networkd_wifi_extra_yaml)${ap_block}
YAML
    secure_netplan_file "$file"
  fi
}

is_wireless() {
  local iface="$1"
  [[ -d "/sys/class/net/${iface}/wireless" ]] || [[ -L "/sys/class/net/${iface}/phy80211" ]]
}

yaml_type() {
  local iface="$1"
  if is_wireless "$iface"; then
    echo "wifis"
  else
    echo "ethernets"
  fi
}

yaml_quote() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  printf '"%s"' "$s"
}

mask_to_prefix() {
  local m="$1"
  local IFS=.
  local o c=0
  read -r o1 o2 o3 o4 <<< "$m"
  for o in "$o1" "$o2" "$o3" "$o4"; do
    case "$o" in
      255) c=$((c + 8));;
      254) c=$((c + 7));;
      252) c=$((c + 6));;
      248) c=$((c + 5));;
      240) c=$((c + 4));;
      224) c=$((c + 3));;
      192) c=$((c + 2));;
      128) c=$((c + 1));;
      0) ;;
      *)
        echo "Invalid netmask: $m" >&2
        exit 2
        ;;
    esac
  done
  echo "$c"
}

prefix_to_mask() {
  local p="$1"
  local mask=""
  local i o
  for ((i = 0; i < 4; i++)); do
    if ((p >= 8)); then
      o=255
      p=$((p - 8))
    elif ((p > 0)); then
      o=$((256 - (1 << (8 - p))))
      p=0
    else
      o=0
    fi
    mask+="${o}"
    ((i < 3)) && mask+="."
  done
  echo "$mask"
}

looks_like_ipv4() {
  [[ "$1" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]
}

iface_exists() {
  [[ -d "/sys/class/net/$1" ]]
}

is_virtual_iface() {
  local iface="$1"
  case "$iface" in
    lo|docker*|veth*|br-*|virbr*|tailscale*|vet*|tun*|tap*|wg*|zt*)
      return 0
      ;;
  esac
  return 1
}

netplan_file_for() {
  local iface="$1"
  echo "${NETPLAN_DIR}/${FILE_PREFIX}-${iface}.yaml"
}

secure_netplan_file() {
  local file="$1"
  chown root:root "$file"
  chmod 600 "$file"
}

ip_link_set() {
  local iface="$1" state="$2"
  ip link set dev "$iface" "$state"
}

format_iface_show() {
  local iface="$1"
  echo "${iface}: mtu $(cat "/sys/class/net/${iface}/mtu" 2>/dev/null || echo ?)  state $(cat "/sys/class/net/${iface}/operstate" 2>/dev/null || echo unknown)"
  ip -4 -o addr show dev "$iface" scope global 2>/dev/null | awk '{print "        inet " $4}' || true
  ip -6 -o addr show dev "$iface" scope global 2>/dev/null | awk '{print "        inet6 " $4}' || true
  local mac
  mac=$(cat "/sys/class/net/${iface}/address" 2>/dev/null || true)
  [[ -n "$mac" ]] && echo "        link/ether ${mac}"
}

show_all() {
  local iface
  for iface in /sys/class/net/*; do
    iface=$(basename "$iface")
    format_iface_show "$iface"
    echo
  done
}

show_iface() {
  local iface="$1"
  format_iface_show "$iface"
  echo
  echo "=== netplan ($(netplan_iface_path "$iface")) ==="
  netplan_merged_config_for_iface "$iface" 2>/dev/null || echo "(not in merged config)"
  if is_wireless "$iface"; then
    echo
    show_wifi_status "$iface"
  fi
}

show_wifi_status() {
  local iface="$1"
  local ssid file

  if command -v iwgetid >/dev/null 2>&1; then
    ssid=$(iwgetid "$iface" -r 2>/dev/null || true)
    if [[ -n "$ssid" ]]; then
      echo "wifi-ssid: $ssid"
    fi
  fi

  if uses_network_manager && command -v nmcli >/dev/null 2>&1; then
    nmcli -t -f GENERAL.CONNECTION,GENERAL.STATE,IP4.ADDRESS device show "$iface" 2>/dev/null \
      | sed 's/^/wifi-/'
  elif command -v networkctl >/dev/null 2>&1; then
    networkctl status "$iface" 2>/dev/null | sed 's/^/wifi-/'
  fi

  file=$(netplan_file_for "$iface")
  if [[ -f "$file" ]]; then
    echo "wifi-npconfig: $file"
  fi
  if IFS=$'\t' read -r ssid _ < <(read_wifi_credentials "$iface" 2>/dev/null) && [[ -n "$ssid" ]]; then
    echo "wifi-config-ssid: $ssid"
  fi
}

wifi_prepare_iface() {
  local iface="$1"
  command -v rfkill >/dev/null 2>&1 && rfkill unblock wifi >/dev/null 2>&1 || true
  ip link set dev "$iface" up 2>/dev/null || true
  if uses_network_manager && command -v nmcli >/dev/null 2>&1; then
    nmcli radio wifi on >/dev/null 2>&1 || true
    nmcli dev set "$iface" managed yes >/dev/null 2>&1 || true
    timeout 20 nmcli dev wifi rescan ifname "$iface" >/dev/null 2>&1 || true
  fi
}

wifi_scan_wpa_supplicant() {
  local iface="$1" outfile="$2"
  local conf pidfile=/run/npconfig-wpa-scan-${iface}.pid started=0

  command -v wpa_supplicant >/dev/null 2>&1 || return 1
  command -v wpa_cli >/dev/null 2>&1 || return 1

  if [[ -S "/run/wpa_supplicant/${iface}" ]] || [[ -S "/var/run/wpa_supplicant/${iface}" ]]; then
    wpa_cli -i "$iface" scan >/dev/null 2>&1 || return 1
  else
    conf=$(mktemp)
    cat >"$conf" <<EOF
ctrl_interface=/run/npconfig-wpa
update_config=0
ap_scan=1
EOF
    mkdir -p /run/npconfig-wpa
    chmod 755 /run/npconfig-wpa
    if ! wpa_supplicant -B -i "$iface" -c "$conf" -D nl80211,wext -P "$pidfile" 2>/dev/null; then
      rm -f "$conf"
      return 1
    fi
    started=1
    sleep 2
    wpa_cli -i "$iface" scan >/dev/null 2>&1 || true
  fi

  sleep 4
  wpa_cli -i "$iface" scan_results 2>/dev/null | awk '
    NR > 1 && $5 != "" {
      ssid=$5
      sub(/^[[:space:]]+/, "", ssid)
      if (ssid != "") printf ":%s:open:%s\n", ssid, $3
    }
  ' >"$outfile"

  if [[ $started -eq 1 && -f "$pidfile" ]]; then
    kill "$(cat "$pidfile")" 2>/dev/null || true
    rm -f "$pidfile" "$conf"
  fi

  [[ -s "$outfile" ]]
}

wifi_scan_to_file() {
  local iface="$1" outfile="$2"
  wifi_prepare_iface "$iface"

  if uses_network_manager && command -v nmcli >/dev/null 2>&1; then
    timeout 20 nmcli -t -f IN-USE,SSID,SECURITY,SIGNAL dev wifi list ifname "$iface" >"$outfile" 2>/dev/null \
      && [[ -s "$outfile" ]] && return 0
  fi

  if wifi_scan_wpa_supplicant "$iface" "$outfile"; then
    return 0
  fi

  if command -v iw >/dev/null 2>&1; then
    timeout 25 iw dev "$iface" scan 2>/dev/null | awk '
      /^BSS / {bssid=$2; sig=""}
      /signal:/ {sig=$2}
      /SSID:/ {
        ssid=substr($0, index($0,":")+2)
        if (ssid != "") printf ":%s:open:%s\n", ssid, sig
      }
    ' >"$outfile"
    [[ -s "$outfile" ]] && return 0
  fi

  return 1
}

wifi_apply_result_text() {
  local iface="$1" out
  out=$(ip -4 -br addr show dev "$iface" 2>/dev/null || true)
  if command -v networkctl >/dev/null 2>&1; then
    out="${out}"$'\n'"$(networkctl status "$iface" 2>/dev/null | sed -n '1,12p')"
  fi
  printf '%s' "$out"
}

wifi_scan() {
  local iface="$1" tmp
  tmp=$(mktemp)
  if wifi_scan_to_file "$iface" "$tmp"; then
    if command -v nmcli >/dev/null 2>&1; then
      printf "IN-USE  SSID  SECURITY  SIGNAL\n"
      while IFS=: read -r inuse ssid security signal; do
        [[ -n "$ssid" ]] || continue
        printf '%s  %s  %s  %s\n' "$inuse" "$ssid" "${security:-open}" "$signal"
      done <"$tmp"
    else
      printf "SSID  SIGNAL\n"
      while IFS=: read -r _ ssid _ signal; do
        [[ -n "$ssid" ]] || continue
        printf '%s  %s\n' "$ssid" "$signal"
      done <"$tmp"
    fi
    rm -f "$tmp"
    return 0
  fi
  rm -f "$tmp"
  echo "npconfig: Wi-Fi scan unavailable; use manual SSID entry (npconfig IFACE wifi SSID ...)" >&2
  exit 1
}

netplan_iface_path() {
  local iface="$1"
  printf '%s.%s' "$(yaml_type "$iface")" "$iface"
}

list_netplan_files() {
  local f
  shopt -s nullglob
  for f in "${NETPLAN_DIR}"/*.yaml; do
    echo "$f"
  done
}

netplan_file_defines_iface() {
  local file="$1" iface="$2"
  [[ -f "$file" ]] || return 1
  awk -v iface="$iface" '
    /^[[:space:]]*(ethernets|wifis):[[:space:]]*$/ { in_types=1; next }
    in_types && $0 ~ "^[[:space:]]*" iface ":[[:space:]]*$" { found=1 }
    in_types && $0 ~ "^[[:space:]]*" iface ":[[:space:]]*" { found=1 }
    END { exit !found }
  ' "$file"
}

netplan_files_for_iface() {
  local iface="$1" f
  while IFS= read -r f; do
    netplan_file_defines_iface "$f" "$iface" && echo "$f"
  done < <(list_netplan_files)
}

netplan_get_value() {
  local path="$1"
  netplan get "$path" 2>/dev/null | sed 's/^"\(.*\)"$/\1/'
}

netplan_merged_config_for_iface() {
  local iface="$1"
  netplan get "$(netplan_iface_path "$iface")" 2>&1
}

netplan_config_mode_for_iface() {
  local iface="$1" path dhcp addr
  path=$(netplan_iface_path "$iface")
  dhcp=$(netplan get "${path}.dhcp4" 2>/dev/null || true)
  addr=$(netplan get "${path}.addresses.0" 2>/dev/null | tr -d '"' || true)
  if [[ "$dhcp" == "true" ]]; then
    echo "dhcp"
  elif [[ -n "$addr" ]]; then
    echo "static (${addr})"
  elif netplan_file_defines_iface "$(netplan_file_for "$iface")" "$iface" 2>/dev/null \
    || netplan_files_for_iface "$iface" | grep -q .; then
    echo "defined (see netplan)"
  else
    echo "not configured"
  fi
}

read_wifi_credentials() {
  local iface="$1" f ssid password
  f=$(netplan_file_for "$iface")
  if [[ -f "$f" ]]; then
    ssid=$(awk '
      /^[[:space:]]*access-points:/ {show=1}
      show && /^[[:space:]]*"/ {
        gsub(/^[[:space:]]*"/, "", $0)
        gsub(/":.*/, "", $0)
        print $0
        exit
      }
    ' "$f" 2>/dev/null || true)
    password=$(awk '
      /password:/ {
        gsub(/^[[:space:]]*password:[[:space:]]*/, "", $0)
        gsub(/^"/, "", $0)
        gsub(/"$/, "", $0)
        print $0
        exit
      }
    ' "$f" 2>/dev/null || true)
    if [[ -n "$ssid" ]]; then
      printf '%s\t%s\n' "$ssid" "$password"
      return 0
    fi
  fi

  while IFS= read -r f; do
    [[ -f "$f" ]] || continue
    ssid=$(awk -v iface="$iface" '
      $0 ~ "^[[:space:]]*" iface ":[[:space:]]*$" { in_iface=1; next }
      in_iface && /^[[:space:]]*access-points:/ { show=1; next }
      in_iface && /^[[:space:]]*[a-zA-Z0-9_.-]+:/ && !/access-points:/ { in_iface=0 }
      show && /^[[:space:]]*"/ {
        gsub(/^[[:space:]]*"/, "", $0)
        gsub(/":.*/, "", $0)
        print $0
        exit
      }
    ' "$f" 2>/dev/null || true)
    password=$(awk -v iface="$iface" '
      $0 ~ "^[[:space:]]*" iface ":[[:space:]]*$" { in_iface=1; next }
      in_iface && /password:/ {
        gsub(/^[[:space:]]*password:[[:space:]]*/, "", $0)
        gsub(/^"/, "", $0)
        gsub(/"$/, "", $0)
        print $0
        exit
      }
    ' "$f" 2>/dev/null || true)
    if [[ -n "$ssid" ]]; then
      printf '%s\t%s\n' "$ssid" "$password"
      return 0
    fi
  done < <(netplan_files_for_iface "$iface")

  ssid=$(netplan get "wifis.${iface}.access-points" 2>/dev/null | head -1 | sed -n 's/^[[:space:]]*"\([^"]*\)".*/\1/p')
  if [[ -n "$ssid" ]]; then
    password=$(netplan get "wifis.${iface}.access-points.\"${ssid}\".password" 2>/dev/null | tr -d '"' || true)
    printf '%s\t%s\n' "$ssid" "$password"
    return 0
  fi
  return 1
}

default_ipv4_for_iface() {
  local iface="$1" cidr ip prefix
  cidr=$(netplan get "$(netplan_iface_path "$iface").addresses.0" 2>/dev/null | tr -d '"' || true)
  if [[ -z "$cidr" ]]; then
    cidr=$(ip -4 -o addr show dev "$iface" scope global 2>/dev/null | awk '{print $4}' | head -1)
  fi
  [[ -n "$cidr" ]] || return 1
  ip=${cidr%%/*}
  prefix=${cidr##*/}
  if [[ "$prefix" =~ ^[0-9]+$ ]]; then
    printf '%s %s\n' "$ip" "$(prefix_to_mask "$prefix")"
  else
    printf '%s %s\n' "$ip" "255.255.255.0"
  fi
}

append_backend_logs() {
  local log="$1"
  {
    echo
    echo "=== networkctl status ==="
    networkctl status 2>&1 || true
    echo
    echo "=== journal: systemd-networkd (last 30) ==="
    journalctl -u systemd-networkd -n 30 --no-pager 2>&1 || true
    echo
    echo "=== journal: wpa_supplicant (last 30) ==="
    journalctl -u wpa_supplicant@"*" -n 30 --no-pager 2>&1 || journalctl -t wpa_supplicant -n 30 --no-pager 2>&1 || true
    echo
    echo "=== merged netplan (netplan get) ==="
    netplan get 2>&1 | head -100 || true
  } >>"$log"
}

apply_netplan() {
  local f log rc=0
  mkdir -p "$NP_LOG_DIR"
  log=$(mktemp "${NP_LOG_DIR}/apply.XXXXXX")
  NETPLAN_LAST_LOG="$log"

  {
    echo "=== npconfig netplan apply $(date -Is) ==="
    echo "renderer: $(detect_netplan_renderer)"
    echo
    echo "=== /etc/netplan files ==="
    list_netplan_files | sed 's/^/  /'
    echo
  } >"$log"

  shopt -s nullglob
  for f in "${NETPLAN_DIR}/${FILE_PREFIX}-"*.yaml; do
    secure_netplan_file "$f"
  done

  {
    echo "=== netplan generate ==="
    netplan generate
  } >>"$log" 2>&1 || rc=1

  if [[ $rc -eq 0 ]]; then
    {
      echo
      echo "=== netplan apply --debug ==="
      timeout 90 netplan apply --debug
    } >>"$log" 2>&1 || rc=1
  fi

  if [[ $rc -ne 0 ]]; then
    append_backend_logs "$log"
    return 1
  fi

  {
    echo
    echo "=== apply succeeded ==="
  } >>"$log"
  return 0
}

print_apply_error() {
  echo "npconfig: netplan apply failed." >&2
  if [[ -n "$NETPLAN_LAST_LOG" && -f "$NETPLAN_LAST_LOG" ]]; then
    echo "npconfig: full log: ${NETPLAN_LAST_LOG}" >&2
    echo "--- begin netplan log ---" >&2
    cat "$NETPLAN_LAST_LOG" >&2
    echo "--- end netplan log ---" >&2
  fi
}

show_apply_error_dialog() {
  local tmp
  tmp=$(mktemp)
  {
    echo "netplan apply failed."
    echo
    if [[ -n "$NETPLAN_LAST_LOG" && -f "$NETPLAN_LAST_LOG" ]]; then
      cat "$NETPLAN_LAST_LOG"
    else
      echo "No log captured."
    fi
  } >"$tmp"
  ui_textbox "Netplan apply failed" "$tmp"
  rm -f "$tmp"
}

apply_netplan_or_show_error() {
  if apply_netplan; then
    return 0
  fi
  if [[ -n "$UI_BIN" ]]; then
    show_apply_error_dialog
  else
    print_apply_error
  fi
  return 1
}

dump_iface_netplan_detail() {
  local iface="$1" f
  echo "=== Live interface ==="
  format_iface_show "$iface" 2>/dev/null || true
  echo
  echo "=== Merged netplan ($(netplan_iface_path "$iface")) ==="
  netplan_merged_config_for_iface "$iface" || true
  echo
  echo "=== Source files mentioning ${iface} ==="
  if netplan_files_for_iface "$iface" | grep -q .; then
    while IFS= read -r f; do
      echo "--- ${f} ---"
      cat "$f"
      echo
    done < <(netplan_files_for_iface "$iface")
  else
    echo "(no netplan source defines ${iface})"
    echo
  fi
  echo "=== All /etc/netplan files ==="
  while IFS= read -r f; do
    echo "--- ${f} ---"
    cat "$f"
    echo
  done < <(list_netplan_files)
  if [[ -n "$NETPLAN_LAST_LOG" && -f "$NETPLAN_LAST_LOG" ]]; then
    echo "=== Last npconfig apply log ==="
    cat "$NETPLAN_LAST_LOG"
  fi
}

show_last_apply_log() {
  local tmp
  tmp=$(mktemp)
  if [[ -n "$NETPLAN_LAST_LOG" && -f "$NETPLAN_LAST_LOG" ]]; then
    cat "$NETPLAN_LAST_LOG" >"$tmp"
  else
    local latest
    latest=$(ls -1t "${NP_LOG_DIR}"/apply.* 2>/dev/null | head -1 || true)
    if [[ -n "$latest" ]]; then
      cat "$latest" >"$tmp"
    else
      echo "No apply logs found in ${NP_LOG_DIR}" >"$tmp"
    fi
  fi
  ui_textbox "Netplan apply log" "$tmp"
  rm -f "$tmp"
}

renew_dhcp_lease() {
  local iface="$1"
  if command -v networkctl >/dev/null 2>&1; then
    networkctl renew "$iface" >/dev/null 2>&1 && return 0
  fi
  if uses_network_manager && command -v nmcli >/dev/null 2>&1; then
    nmcli device reapply "$iface" >/dev/null 2>&1 && return 0
    nmcli device connect "$iface" >/dev/null 2>&1 && return 0
  fi
  if command -v dhclient >/dev/null 2>&1; then
    dhclient -r "$iface" >/dev/null 2>&1 || true
    dhclient "$iface" >/dev/null 2>&1 && return 0
  fi
  apply_netplan
}

iface_status_summary() {
  local iface="$1" kind="${2:-Interface}"
  local state carrier ip gw dns ssid file

  state=$(<"/sys/class/net/${iface}/operstate" 2>/dev/null || echo unknown)
  state=${state^^}
  if [[ -r "/sys/class/net/${iface}/carrier" ]]; then
    carrier=$(<"/sys/class/net/${iface}/carrier")
    [[ "$carrier" == "1" ]] && carrier=YES || carrier=NO
  else
    carrier=n/a
  fi

  ip=$(ip -4 -o addr show dev "$iface" scope global 2>/dev/null | awk '{print $4}' | head -1)
  [[ -z "$ip" ]] && ip=none

  gw=$(ip -4 route show dev "$iface" default 2>/dev/null | awk '{print $3}' | head -1)
  [[ -z "$gw" ]] && gw=$(ip -4 route show default 2>/dev/null | awk '{print $3}' | head -1)
  [[ -z "$gw" ]] && gw=none

  dns=$(awk '/^nameserver / {print $2}' /etc/resolv.conf 2>/dev/null | head -3 | paste -sd, -)
  [[ -z "$dns" ]] && dns=none

  printf '%s: %s\n\nStatus : %s\nCarrier: %s\nIP     : %s\nGateway: %s\nDNS    : %s' \
    "$kind" "$iface" "$state" "$carrier" "$ip" "$gw" "$dns"

  if is_wireless "$iface"; then
    ssid=$(iwgetid "$iface" -r 2>/dev/null || true)
    if [[ -z "$ssid" ]]; then
      IFS=$'\t' read -r ssid _ < <(read_wifi_credentials "$iface" 2>/dev/null || true)
    fi
    [[ -n "$ssid" ]] && printf '\nSSID   : %s' "$ssid"
  fi

  printf '\nNetplan: %s' "$(netplan_config_mode_for_iface "$iface")"
  printf '\nBackend: %s' "$(detect_netplan_renderer)"
}

iface_menu_body() {
  local iface="$1" kind="$2"
  printf '%s\n\n------------------------------\n\nChoose an action:' "$(iface_status_summary "$iface" "$kind")"
}

ui_init() {
  if command -v dialog >/dev/null 2>&1; then
    UI_BIN=dialog
    return 0
  fi
  if command -v whiptail >/dev/null 2>&1; then
    UI_BIN=whiptail
    return 0
  fi
  echo "npconfig: install dialog or whiptail for the interactive menu." >&2
  exit 1
}

ui_msg() {
  local title="$1" text="$2"
  "$UI_BIN" --title "$title" --msgbox "$text" 12 72
}

ui_yesno() {
  local title="$1" text="$2"
  "$UI_BIN" --title "$title" --yesno "$text" 10 72
}

ui_input() {
  local title="$1" prompt="$2" default="${3:-}"
  local out
  out=$("$UI_BIN" --title "$title" --inputbox "$prompt" 10 72 "$default" 3>&1 1>&2 2>&3) || return 1
  printf '%s' "$out"
}

ui_password() {
  local title="$1" prompt="$2"
  local out
  out=$("$UI_BIN" --title "$title" --passwordbox "$prompt" 10 72 3>&1 1>&2 2>&3) || return 1
  printf '%s' "$out"
}

ui_menu() {
  local title="$1" text="$2"
  shift 2
  "$UI_BIN" --title "$title" --menu "$text" 24 78 10 "$@" 3>&1 1>&2 2>&3
}

ui_textbox() {
  local title="$1" file="$2"
  "$UI_BIN" --title "$title" --textbox "$file" 22 78
}

list_physical_ifaces() {
  local want="${1:-all}" iface
  for iface in /sys/class/net/*; do
    iface=$(basename "$iface")
    is_virtual_iface "$iface" && continue
    case "$want" in
      wireless) is_wireless "$iface" || continue ;;
      ethernet) is_wireless "$iface" && continue ;;
    esac
    echo "$iface"
  done
}

iface_menu_pick() {
  local title="$1" want="${2:-all}"
  local items=() iface state ip
  while IFS= read -r iface; do
    [[ -n "$iface" ]] || continue
    state=$(<"/sys/class/net/${iface}/operstate" 2>/dev/null || echo unknown)
    ip=$(ip -4 -o addr show dev "$iface" scope global 2>/dev/null | awk '{print $4}' | head -1)
    [[ -z "$ip" ]] && ip="no-ipv4"
    if is_wireless "$iface"; then
      items+=("$iface" "wifi ${state} ${ip}")
    else
      items+=("$iface" "eth ${state} ${ip}")
    fi
  done < <(list_physical_ifaces "$want")

  ((${#items[@]})) || {
    ui_msg "No interfaces" "No matching network interfaces were found."
    return 1
  }

  ui_menu "$title" "Select an interface:" "${items[@]}"
}

iface_status_text() {
  local iface="$1" tmp
  tmp=$(mktemp)
  {
    if is_wireless "$iface"; then
      echo "=== Wi-Fi runtime ==="
      show_wifi_status "$iface" 2>/dev/null || true
      echo
    fi
    dump_iface_netplan_detail "$iface"
  } >"$tmp"
  ui_textbox "Interface ${iface}" "$tmp"
  rm -f "$tmp"
}

menu_static_ip_form() {
  local title="$1" iface="${2:-}"
  local addr netmask gateway dns1 dns2 defaults
  if [[ -n "$iface" ]]; then
    defaults=$(default_ipv4_for_iface "$iface" 2>/dev/null || true)
    if [[ -n "$defaults" ]]; then
      read -r addr netmask <<<"$defaults"
    fi
    read -r gateway dns1 dns2 < <(static_defaults_for_iface "$iface")
  fi
  [[ -z "${addr:-}" ]] && addr="192.168.1.50"
  [[ -z "${netmask:-}" ]] && netmask="255.255.255.0"
  [[ -z "${gateway:-}" ]] && gateway="192.168.1.1"
  [[ -z "${dns1:-}" ]] && dns1="1.1.1.1"
  [[ -z "${dns2:-}" ]] && dns2="8.8.8.8"
  addr=$(ui_input "$title" "IPv4 address:" "$addr") || return 1
  looks_like_ipv4 "$addr" || {
    ui_msg "Invalid IP" "That does not look like a valid IPv4 address."
    return 1
  }
  netmask=$(ui_input "$title" "Netmask:" "$netmask") || return 1
  looks_like_ipv4 "$netmask" || {
    ui_msg "Invalid netmask" "That does not look like a valid netmask."
    return 1
  }
  gateway=$(ui_input "$title" "Gateway:" "$gateway") || return 1
  looks_like_ipv4 "$gateway" || {
    ui_msg "Invalid gateway" "That does not look like a valid gateway address."
    return 1
  }
  dns1=$(ui_input "$title" "Primary DNS:" "$dns1") || return 1
  looks_like_ipv4 "$dns1" || {
    ui_msg "Invalid DNS" "That does not look like a valid DNS address."
    return 1
  }
  dns2=$(ui_input "$title" "Secondary DNS:" "$dns2") || return 1
  looks_like_ipv4 "$dns2" || {
    ui_msg "Invalid DNS" "That does not look like a valid DNS address."
    return 1
  }
  printf '%s %s %s %s %s\n' "$addr" "$netmask" "$gateway" "$dns1" "$dns2"
}

menu_configure_ethernet() {
  local iface choice addr netmask prefix body
  iface=$(iface_menu_pick "Ethernet interface" ethernet) || return 0

  while true; do
    body=$(iface_menu_body "$iface" "Ethernet")
    choice=$(ui_menu "Ethernet: ${iface}" "$body" \
      dhcp "Use DHCP" \
      static "Configure Static IPv4" \
      up "Bring Interface Up" \
      down "Bring Interface Down" \
      renew "Renew DHCP Lease" \
      netplan "View Netplan Config" \
      log "Show Last Apply Log" \
      status "Show Detailed Status" \
      back "Back") || return 0

    case "$choice" in
      dhcp)
        write_netplan_dhcp "$iface"
        apply_netplan_or_show_error || continue
        ip_link_set "$iface" up || true
        ui_msg "Applied" "DHCP enabled for ${iface}.\n\n$(ip -4 -br addr show dev "$iface" 2>/dev/null || true)"
        ;;
      static)
        read -r addr netmask gateway dns1 dns2 < <(menu_static_ip_form "Static IP: ${iface}" "$iface") || continue
        prefix=$(mask_to_prefix "$netmask")
        write_netplan_static "$iface" "$addr" "$prefix" "$gateway" "$dns1" "$dns2"
        apply_netplan_or_show_error || continue
        ip_link_set "$iface" up || true
        ui_msg "Applied" "Static IP set on ${iface}:\n${addr}/${prefix}"
        ;;
      up)
        ip_link_set "$iface" up
        ;;
      down)
        ip_link_set "$iface" down
        ;;
      renew)
        renew_dhcp_lease "$iface"
        ui_msg "DHCP renewed" "Requested DHCP renewal on ${iface}.\n\n$(ip -4 -br addr show dev "$iface" 2>/dev/null || true)"
        ;;
      netplan)
        iface_status_text "$iface"
        ;;
      log)
        show_last_apply_log
        ;;
      status)
        iface_status_text "$iface"
        ;;
      back)
        return 0
        ;;
    esac
  done
}

menu_wifi_pick_network() {
  local iface="$1"
  local scan_file map_file items=() ssid security signal inuse tag idx=0
  scan_file=$(mktemp)
  map_file="${scan_file}.map"

  ui_msg "Wi-Fi scan" "Scanning on ${iface}.\nThis may take up to 20 seconds."
  if ! wifi_scan_to_file "$iface" "$scan_file"; then
    rm -f "$scan_file" "$map_file"
    ui_msg "Scan failed" "Could not scan Wi-Fi on ${iface}.\n\nBackend: $(detect_netplan_renderer)\n\nUse \"Connect to Hidden/Custom SSID\" and enter the network name manually.\n\nStock Ubuntu server uses networkd + wpa_supplicant (no extra packages)."
    return 1
  fi

  while IFS=: read -r inuse ssid security signal; do
    [[ -n "$ssid" ]] || continue
    idx=$((idx + 1))
    tag="net${idx}"
    items+=("$tag" "${ssid}  ${signal}%  ${security:-open}  ${inuse:+[connected]}")
    printf '%s\t%s\n' "$tag" "$ssid" >>"$map_file"
  done <"$scan_file"

  rm -f "$scan_file"
  ((${#items[@]})) || {
    rm -f "$map_file"
    ui_msg "No networks" "No Wi-Fi networks were found.\n\nTry manual SSID entry or check that the adapter is up."
    return 1
  }

  items+=("manual" "Enter SSID manually")
  tag=$(ui_menu "Wi-Fi scan: ${iface}" "Select a network:" "${items[@]}") || {
    rm -f "$map_file"
    return 1
  }
  if [[ "$tag" == "manual" ]]; then
    rm -f "$map_file"
    ui_input "Wi-Fi SSID" "Enter network name (SSID):" ""
    return 0
  fi
  awk -F '\t' -v t="$tag" '$1==t {print $2; exit}' "$map_file"
  rm -f "$map_file"
}

menu_configure_wifi() {
  local iface choice ssid password security hidden addr netmask prefix file body gateway dns1 dns2
  iface=$(iface_menu_pick "Wi-Fi interface" wireless) || return 0

  while true; do
    body=$(iface_menu_body "$iface" "Wi-Fi")
    choice=$(ui_menu "Wi-Fi: ${iface}" "$body" \
      scan "Scan and Connect" \
      manual "Connect to Hidden/Custom SSID" \
      dhcp "Reconnect Saved SSID (DHCP)" \
      static "Reconnect Saved SSID (Static IP)" \
      up "Bring Interface Up" \
      down "Bring Interface Down" \
      renew "Renew DHCP Lease" \
      netplan "View Netplan Config" \
      log "Show Last Apply Log" \
      status "Show Detailed Status" \
      back "Back") || return 0

    case "$choice" in
      scan)
        ssid=$(menu_wifi_pick_network "$iface") || continue
        [[ -n "$ssid" ]] || continue
        if uses_network_manager && command -v nmcli >/dev/null 2>&1; then
          security=$(timeout 10 nmcli -t -f SSID,SECURITY dev wifi list ifname "$iface" 2>/dev/null | awk -F: -v s="$ssid" '$1==s{print $2; exit}')
        else
          security=""
        fi
        if [[ -n "$security" && "$security" != "--" ]]; then
          password=$(ui_password "Wi-Fi password" "Password for ${ssid}:") || continue
        else
          ui_yesno "Wi-Fi security" "Does ${ssid} require a password?" && {
            password=$(ui_password "Wi-Fi password" "Password for ${ssid}:") || continue
          } || password=""
        fi
        write_netplan_wifi "$iface" "$ssid" "$password"
        apply_netplan_or_show_error || continue
        ip_link_set "$iface" up || true
        sleep 3
        ui_msg "Applied" "Connected ${iface} to:\n${ssid}\n\n$(wifi_apply_result_text "$iface")"
        ;;
      manual)
        hidden=0
        ui_yesno "Hidden SSID" "Is this a hidden Wi-Fi network?" && hidden=1 || hidden=0
        ssid=$(ui_input "Wi-Fi SSID" "Network name:" "") || continue
        [[ -n "$ssid" ]] || continue
        ui_yesno "Security" "Does ${ssid} require a password?" && {
          password=$(ui_password "Wi-Fi password" "Password for ${ssid}:") || continue
        } || password=""
        write_netplan_wifi "$iface" "$ssid" "$password" "" "" "$hidden"
        apply_netplan_or_show_error || continue
        ip_link_set "$iface" up || true
        sleep 3
        ui_msg "Applied" "Configured ${iface} for SSID:\n${ssid}\n\n$(wifi_apply_result_text "$iface")"
        ;;
      dhcp)
        if ! IFS=$'\t' read -r ssid password < <(read_wifi_credentials "$iface" 2>/dev/null); then
          ui_msg "No saved SSID" "No Wi-Fi config found for ${iface} in netplan.\nUse scan/manual connect first."
          continue
        fi
        [[ -n "$ssid" ]] || {
          ui_msg "No saved SSID" "Could not read SSID from netplan for ${iface}."
          continue
        }
        write_netplan_wifi "$iface" "$ssid" "$password"
        apply_netplan_or_show_error || continue
        ip_link_set "$iface" up || true
        ui_msg "Applied" "DHCP reapplied for ${ssid} on ${iface}."
        ;;
      static)
        if ! IFS=$'\t' read -r ssid password < <(read_wifi_credentials "$iface" 2>/dev/null); then
          ui_msg "No saved SSID" "No Wi-Fi config found for ${iface} in netplan."
          continue
        fi
        read -r addr netmask gateway dns1 dns2 < <(menu_static_ip_form "Static Wi-Fi: ${iface}" "$iface") || continue
        prefix=$(mask_to_prefix "$netmask")
        write_netplan_wifi "$iface" "$ssid" "$password" "$addr" "$prefix" 0 "$gateway" "$dns1" "$dns2"
        apply_netplan_or_show_error || continue
        ip_link_set "$iface" up || true
        ui_msg "Applied" "Static IP set on ${iface} for ${ssid}:\n${addr}/${prefix}"
        ;;
      up)
        ip_link_set "$iface" up
        ;;
      down)
        ip_link_set "$iface" down
        ;;
      renew)
        renew_dhcp_lease "$iface"
        ui_msg "DHCP renewed" "Requested DHCP renewal on ${iface}.\n\n$(ip -4 -br addr show dev "$iface" 2>/dev/null || true)"
        ;;
      netplan)
        iface_status_text "$iface"
        ;;
      log)
        show_last_apply_log
        ;;
      status)
        iface_status_text "$iface"
        ;;
      back)
        return 0
        ;;
    esac
  done
}

menu_show_all_status() {
  local tmp
  tmp=$(mktemp)
  {
    echo "=== links ==="
    ip -br link show
    echo
    echo "=== addresses ==="
    ip -br addr show
    echo
    echo "=== all netplan files ==="
    while IFS= read -r f; do
      echo "--- ${f} ---"
      cat "$f"
      echo
    done < <(list_netplan_files)
  } >"$tmp" 2>&1 || true
  ui_textbox "All interfaces" "$tmp"
  rm -f "$tmp"
}

menu_show_one_status() {
  local iface
  iface=$(iface_menu_pick "Show interface" all) || return 0
  iface_status_text "$iface"
}

menu_apply_netplan() {
  if ui_yesno "Apply netplan" "Regenerate and apply all netplan configuration now?"; then
    if apply_netplan_or_show_error; then
      ui_msg "Done" "netplan apply completed."
    fi
  fi
}

menu_main() {
  local choice tmp
  [[ -t 0 ]] || {
    echo "npconfig menu requires an interactive terminal." >&2
    exit 1
  }

  ui_init
  set +e

  while true; do
    choice=$(ui_menu "npconfig" "Network setup menu\nReads all ${NETPLAN_DIR}/*.yaml\nWrites ${FILE_PREFIX}-IFACE.yaml overlays" \
      ethernet "Configure Ethernet" \
      wifi "Configure Wi-Fi" \
      status "Show one interface" \
      all "Show all interfaces" \
      netplan "View all netplan files" \
      log "Show last apply log" \
      apply "Apply netplan now" \
      quit "Exit") || exit 0

    case "$choice" in
      ethernet) menu_configure_ethernet ;;
      wifi) menu_configure_wifi ;;
      status) menu_show_one_status ;;
      all) menu_show_all_status ;;
      netplan)
        tmp=$(mktemp)
        {
          while IFS= read -r f; do
            echo "=== ${f} ==="
            cat "$f"
            echo
          done < <(list_netplan_files)
        } >"$tmp" 2>&1
        ui_textbox "All netplan files" "$tmp"
        rm -f "$tmp"
        ;;
      log) show_last_apply_log ;;
      apply) menu_apply_netplan ;;
      quit) exit 0 ;;
    esac
  done
}

usage() {
  cat <<USAGE
ifconfig-compatible usage:
  npconfig
  npconfig -a
  npconfig IFACE
  npconfig IFACE up
  npconfig IFACE down
  npconfig IFACE inet dhcp
  npconfig IFACE A.B.C.D netmask M.M.M.M [broadcast B.B.B.B] [up]

Wi-Fi extensions:
  npconfig IFACE wifi
  npconfig IFACE wifi scan
  npconfig IFACE wifi SSID open inet dhcp [up]
  npconfig IFACE wifi SSID passphrase PASSWORD inet dhcp [up]
  npconfig IFACE wifi SSID psk PASSWORD A.B.C.D netmask M.M.M.M [up]
  npconfig IFACE wifi --hidden SSID passphrase PASSWORD inet dhcp [up]

Interactive menu:
  npconfig menu
  npconfig --menu
  npconfig -m

Notes:
- Settings persist in /etc/netplan/${FILE_PREFIX}-IFACE.yaml
- Auto-detects netplan renderer: NetworkManager (desktop) or networkd (server)
- Wi-Fi on server uses stock networkd + wpa_supplicant; scan via wpa_cli when available
- Menu uses dialog or whiptail (install one if missing)
- Uses iproute2 (ip) only; no extra packages required on stock Ubuntu
USAGE
}

parse_wifi_args() {
  local iface="$1"
  shift

  if [[ $# -eq 0 ]]; then
    show_wifi_status "$iface"
    exit 0
  fi

  if [[ "$1" == "scan" ]]; then
    wifi_scan "$iface"
    exit 0
  fi

  local hidden=0 ssid="" password="" dhcp=1 addr="" netmask="" bring_up=0

  if [[ "$1" == "--hidden" ]]; then
    hidden=1
    shift
  fi

  [[ $# -gt 0 ]] || { echo "npconfig: Wi-Fi SSID missing" >&2; exit 2; }
  ssid="$1"
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      open)
        password=""
        ;;
      passphrase|psk|password)
        shift
        [[ $# -gt 0 ]] || { echo "npconfig: Wi-Fi password missing" >&2; exit 2; }
        password="$1"
        ;;
      inet)
        shift
        [[ $# -gt 0 && "$1" == "dhcp" ]] || { echo "npconfig: expected 'inet dhcp'" >&2; exit 2; }
        dhcp=1
        ;;
      dhcp)
        dhcp=1
        ;;
      netmask)
        shift
        [[ $# -gt 0 ]] || { echo "npconfig: netmask value missing" >&2; exit 2; }
        netmask="$1"
        dhcp=0
        ;;
      broadcast)
        shift
        [[ $# -gt 0 ]] || { echo "npconfig: broadcast value missing" >&2; exit 2; }
        ;;
      up)
        bring_up=1
        ;;
      down)
        ip_link_set "$iface" down
        exit 0
        ;;
      *)
        if looks_like_ipv4 "$1"; then
          addr="$1"
          dhcp=0
        else
          echo "npconfig: unsupported Wi-Fi token '$1'" >&2
          usage
          exit 2
        fi
        ;;
    esac
    shift || true
  done

  if ! is_wireless "$iface"; then
    echo "npconfig: '$iface' is not a wireless interface" >&2
    exit 1
  fi

  if [[ $dhcp -eq 1 && -z "$addr" ]]; then
    write_netplan_wifi "$iface" "$ssid" "$password" "" "" "$hidden"
  else
    [[ -n "$addr" && -n "$netmask" ]] || {
      echo "npconfig: static Wi-Fi requires IP and netmask" >&2
      exit 2
    }
    local prefix
    prefix=$(mask_to_prefix "$netmask")
    write_netplan_wifi "$iface" "$ssid" "$password" "$addr" "$prefix" "$hidden"
  fi

  apply_netplan_or_show_error || exit 1
  if [[ $bring_up -eq 1 ]]; then
    ip_link_set "$iface" up || true
  fi
}

if [[ $# -eq 0 ]]; then
  show_all
  exit 0
fi

if [[ "$1" == "-a" ]]; then
  show_all
  exit 0
fi

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  usage
  exit 0
fi

if [[ "$1" == "menu" || "$1" == "--menu" || "$1" == "-m" ]]; then
  menu_main
  exit 0
fi

iface="$1"
shift || true

if ! iface_exists "$iface"; then
  echo "npconfig: interface '$iface' does not exist" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  show_iface "$iface"
  exit 0
fi

if [[ "$1" == "wifi" ]]; then
  shift
  parse_wifi_args "$iface" "$@"
  exit 0
fi

if [[ "$1" == "up" || "$1" == "down" ]]; then
  ip_link_set "$iface" "$1"
  exit 0
fi

if [[ $# -ge 2 && "$1" == "inet" && "$2" == "dhcp" ]]; then
  write_netplan_dhcp "$iface"
  apply_netplan_or_show_error || exit 1
  exit 0
fi

addr="$1"
shift

if ! looks_like_ipv4 "$addr"; then
  echo "npconfig: unsupported command starting with '$addr'" >&2
  usage
  exit 2
fi

netmask=""
bring_up=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    netmask)
      shift
      [[ $# -gt 0 ]] || { echo "npconfig: netmask value missing" >&2; exit 2; }
      netmask="$1"
      ;;
    broadcast)
      shift
      [[ $# -gt 0 ]] || { echo "npconfig: broadcast value missing" >&2; exit 2; }
      ;;
    up)
      bring_up=1
      ;;
    down)
      ip_link_set "$iface" down
      exit 0
      ;;
    *)
      echo "npconfig: unsupported token '$1'" >&2
      usage
      exit 2
      ;;
  esac
  shift || true
done

[[ -n "$netmask" ]] || { echo "npconfig: netmask is required for static IPv4" >&2; exit 2; }
prefix=$(mask_to_prefix "$netmask")
write_netplan_static "$iface" "$addr" "$prefix"
apply_netplan_or_show_error || exit 1

if [[ $bring_up -eq 1 ]]; then
  ip_link_set "$iface" up
fi

exit 0
